# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carburapp

# Set to 'development' locally
NODE_ENV=development

# iron-session secret — must be at least 32 random characters
SESSION_SECRET=replace-with-at-least-32-random-chars

# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile)
# Local dev test keys: site=1x00000000000000000000AA  secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-your-site-key
TURNSTILE_SECRET_KEY=replace-with-your-secret-key
